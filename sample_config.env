# ============================================================
# Telegram Stremio - Startup Critical Config Only
# ============================================================
# Hugging Face Spaces: set these in Space Settings > Secrets.
# All other settings are managed from /admin/config.

# Telegram (Required)
API_ID=""
API_HASH=""
BOT_TOKEN=""
HELPER_BOT_TOKEN=""
OWNER_ID=""

# Database (Required - exactly 2 comma-separated URIs: tracking, storage_1)
DATABASE=""

# Server (Required)
# Hugging Face Spaces uses port 7860.
PORT="7860"

# ============================================================
# Managed from WebUI after startup: /admin/config
# ============================================================
# Examples: BASE_URL, AUTH_CHANNEL, TMDB_API, ADMIN_USERNAME,
# ADMIN_PASSWORD, REPLACE_MODE, HIDE_CATALOG, SUBSCRIPTION, etc.
